<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings - Musico</title>
  <link rel="stylesheet" href="/css/settings.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"/>
</head>
<body>
  <header>
    <h1>⚙️ Settings</h1>
    <a href="/music" class="back-btn"><i class="fa-solid fa-arrow-left"></i> Back</a>
  </header>

  <main class="settings-container">
    <div class="glass">
      <span><i class="fa-solid fa-moon"></i> Dark Mode</span>
      <label class="switch">
        <input type="checkbox" id="darkMode">
        <span class="slider"></span>
      </label>
    </div>

    
  </main>

  <footer>© 2025 Musico | Your preferences are saved automatically</footer>

  <script src="/js/settings.js"></script>
  <script src="/js/theme.js"></script>


</body>
</html>
