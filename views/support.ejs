<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Support - Musico</title>
  <link rel="stylesheet" href="/css/support.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"/>
  <script src="/js/theme.js"></script>
</head>
<body>

<header>
  <h1>🎧 Support</h1>
  <a href="/music" class="back-btn">
    <i class="fa-solid fa-arrow-left"></i> Back
  </a>
</header>

<main class="support-container">
  <div class="support-card">
    <p class="support-intro">
      We're here to help! Fill out the form below and we'll get back to you soon.
    </p>

    <!-- ✅ id="supportForm" -->
    <form id="supportForm">

      <input 
        type="text" 
        id="supportName" 
        placeholder="Your Name" 
        required 
      />

      <input 
        type="email" 
        id="supportEmail" 
        placeholder="Your Email" 
        required 
      />

      <textarea 
        id="supportMessage" 
        placeholder="Describe your issue..." 
        rows="6" 
        required
      ></textarea>

      <!-- ✅ Status message shown after submit -->
      <p id="statusMsg" style="text-align:center; font-size:14px; margin-bottom:10px;"></p>

      <button type="submit" id="submitBtn">Submit</button>

    </form>
  </div>
</main>

<footer>© 2025 Musico | Support</footer>

<script src="/js/support.js"></script>

</body>
</html>