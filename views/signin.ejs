<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Sign In - Musico</title>

  <!-- CSS -->
  <link rel="stylesheet" href="/css/signin.css"/>
</head>

<body>

<main>
  <div class="form-box">
    <h2>Sign In</h2>

    <form id="signin-form">
      <input type="email" id="signinEmail" placeholder="Email" required/>

      <div class="password-wrapper">
        <input type="password" id="signinPassword" placeholder="Password" required/>
        <span class="toggle-password" id="toggleSignInPassword">👁️</span>
      </div>

      <button type="submit">Sign In</button>

      <!-- ✅ FIXED LINKS -->
      <a href="/forgot" style="color:lightblue;">Forgot Password?</a>  
      <p>
        Don't have an account? 
        <a href="/signup" style="color:lightblue;">Sign Up</a>
      </p>

    </form>
  </div>
</main>

<!-- JS -->
<script src="/js/signin.js" defer></script>

</body>
</html>